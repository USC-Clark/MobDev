<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BMI_Calculator_App.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30"
            Spacing="20">

         <Label 
            Text="BMI Calculator"
            FontSize="28"
            HorizontalOptions="Center" />

         <Entry
            x:Name="HeightEntry"
            Placeholder="Enter height in meters (e.g., 1.75)"
            Keyboard="Numeric" />

         <Entry
            x:Name="WeightEntry"
            Placeholder="Enter weight in kg"
            Keyboard="Numeric" />

         <Button
            x:Name="CalculateBtn"
            Text="Calculate BMI"
            Clicked="OnCalculateClicked" />

         <Label
            x:Name="ResultLabel"
            FontSize="18"
            TextColor="Blue" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
